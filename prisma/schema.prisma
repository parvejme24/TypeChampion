generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  fullName        String
  avatarUrl       String?
  userCreatedDate DateTime
  lastLoginTime   DateTime
  isBlocked       Boolean  @default(false)
  role            String   @default("user")

  scores          Score[]
}

model Score {
  id              Int       @id @default(autoincrement())
  userEmail       String?
  userName        String
  wpm             Int
  accuracy        Float
  correctChars    Int
  wrongChars      Int
  totalChars      Int
  durationSeconds Int?
  paragraphId     Int?
  paragraphTitle  String?
  paragraphText   String?   @db.Text
  typedText       String?   @db.Text
  createdAt       DateTime  @default(now())

  user      User?      @relation(fields: [userEmail], references: [email], onDelete: SetNull)
  paragraph Paragraph? @relation(fields: [paragraphId], references: [id], onDelete: SetNull)
}

model Paragraph {
  id             Int      @id @default(autoincrement())
  title          String
  text           String   @db.Text
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  createdByEmail String?

  scores Score[]
}

